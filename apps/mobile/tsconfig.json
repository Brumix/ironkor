{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@convex/*": [
        "../../convex/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@ironkor/shared": [
        "../../packages/shared/constants.ts"
      ],
      "@ironkor/shared/*": [
        "../../packages/shared/*.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
