{
  "name": "ironkor-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -r \"bun run convex:dev\" \"bun run mobile:dev\"",
    "start": "bun run convex:dev:once && concurrently -r \"bun run convex:dev\" \"bun run mobile:dev\"",
    "postinstall": "node ./scripts/fix-react-native-draggable-flatlist.mjs",
    "convex:dev": "convex dev",
    "convex:dev:once": "convex dev --once",
    "convex:deploy": "convex deploy",
    "mobile:dev": "bun run --cwd apps/mobile dev:expo",
    "mobile:doctor": "bun run --cwd apps/mobile doctor",
    "mobile:start": "bun run --cwd apps/mobile start",
    "quality:mobile": "bun run lint && bun run mobile:doctor && bun run typecheck",
    "lint": "bun run --cwd apps/mobile lint",
    "lint:strict": "bun run --cwd apps/mobile lint:strict",
    "test": "vitest run",
    "test:mobile": "vitest run apps/mobile/tests",
    "test:convex": "vitest run convex/tests",
    "typecheck": "tsc --noEmit -p apps/mobile/tsconfig.json && tsc --noEmit -p convex/tsconfig.json",
    "lockfile:check": "node ./scripts/check-bun-lockfiles.mjs"
  },
  "dependencies": {
    "@ironkor/shared": "workspace:*"
  },
  "devDependencies": {
    "@convex-dev/migrations": "^0.3.3",
    "@edge-runtime/vm": "^5.0.0",
    "concurrently": "^9.2.1",
    "convex": "^1.32.0",
    "convex-test": "^0.0.44",
    "eslint-import-context": "^0.1.8",
    "ms": "^2.1.3",
    "stable-hash-x": "^0.2.0",
    "tinyglobby": "^0.2.14",
    "vitest": "^4.1.2"
  },
  "patchedDependencies": {
    "expo-router@55.0.8": "patches/expo-router@55.0.8.patch",
    "react-native-draggable-flatlist@4.0.3": "patches/react-native-draggable-flatlist@4.0.3.patch"
  }
}
