{
  "name": "ironkor",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -r \"bun run convex:dev\" \"bun run mobile:dev\"",
    "start": "bun run convex:dev:once && concurrently -r \"bun run convex:dev\" \"bun run mobile:dev\"",
    "convex:dev": "convex dev",
    "convex:dev:once": "convex dev --once",
    "convex:deploy": "convex deploy",
    "mobile:dev": "bun run --cwd apps/mobile dev:expo",
    "mobile:start": "bun run --cwd apps/mobile start",
    "lint": "bun run --cwd apps/mobile lint",
    "typecheck": "tsc --noEmit -p apps/mobile/tsconfig.json && tsc --noEmit -p convex/tsconfig.json"
  },
  "dependencies": {
    "@ironkor/shared": "workspace:*"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "convex": "^1.32.0"
  },
  "patchedDependencies": {
    "react-native-draggable-flatlist@4.0.3": "patches/react-native-draggable-flatlist@4.0.3.patch"
  }
}
